# Twilio — twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# OpenAI — platform.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your public server URL (use ngrok for local testing)
# Run: ngrok http 8000 → copy the https URL here
SERVER_URL=https://xxxx.ngrok.io

# The phone number to call (your own number to test)
CALL_TO_NUMBER=+1xxxxxxxxxx
